<section class="soul-chargen">
  <h3>SOUL Character Framework</h3>
  {{#if isLoading}}<p class="text-muted">Saving…</p>{{/if}}
  {{#if error}}<div class="alert alert-danger">{{error}}</div>{{/if}}

  {{#if status}}
    <div class="alert alert-info">
      <strong>Skill Points:</strong> {{status.points_spent}} / {{status.skill_points}} spent;
      {{status.points_remaining}} remaining.
      <strong class="ms-2">Starting cap:</strong> {{status.starting_cap}}.
    </div>

    {{#if status.resonance_enabled}}
      <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
          <strong>Resonance</strong>
          <span class="badge bg-primary">Current: {{status.resonance_label}}</span>
        </div>
        <div class="card-body">
          <p class="cg-tip">Resonance determines your starting Skill-point allowance and starting cap.</p>
          <div class="btn-group flex-wrap" role="group" aria-label="Select Resonance">
            {{#each status.resonance_options as |value|}}
              <button type="button" class="btn btn-outline-primary"
                onclick={{action "setResonance" value}}>R{{value}}</button>
            {{/each}}
          </div>
        </div>
      </div>
    {{/if}}

    <div class="row">
      {{#each status.aspects as |aspect|}}
        <div class="col-lg-4 col-md-6 mb-3">
          <div class="card h-100">
            <div class="card-header"><strong>{{aspect.name}}</strong></div>
            <div class="card-body p-0">
              {{#each status.skills as |skill|}}
                {{#if (eq skill.aspect_key aspect.key)}}
                  <div class="d-flex justify-content-between align-items-center gap-2 p-3 border-bottom soul-chargen-skill">
                    <div>
                      <strong>{{skill.name}}</strong>
                      <div class="small text-muted">[{{skill.key}}]</div>
                    </div>
                    <div class="d-flex align-items-center gap-2" role="group"
                      aria-label="Set {{skill.name}} rating">
                      <button type="button" class="btn btn-sm btn-outline-secondary"
                        disabled={{eq skill.rating 0}}
                        onclick={{action "adjustSkill" skill -1}} aria-label="Decrease {{skill.name}}">−</button>
                      <span class="badge bg-primary fs-6">{{skill.rating}}</span>
                      <button type="button" class="btn btn-sm btn-outline-secondary"
                        disabled={{eq skill.rating status.starting_cap}}
                        onclick={{action "adjustSkill" skill 1}} aria-label="Increase {{skill.name}}">+</button>
                    </div>
                  </div>
                {{/if}}
              {{/each}}
            </div>
          </div>
        </div>
      {{/each}}
    </div>

    <div class="card mb-3">
      <div class="card-header"><strong>Starting Boons &amp; Banes</strong></div>
      <div class="card-body">
        {{#if status.has_selected_bnb}}
          <div class="table-responsive mb-3">
            <table class="table table-sm">
              <thead><tr><th scope="col">Entry</th><th scope="col">Kind</th><th scope="col">Level</th><th scope="col"></th></tr></thead>
              <tbody>
                {{#each status.selected_bnb as |entry|}}
                  <tr>
                    <td>{{entry.name}} <span class="text-muted">[{{entry.tag}}]</span></td>
                    <td>{{entry.kind}}</td>
                    <td>{{entry.level_state}}</td>
                    <td class="text-end"><button type="button" class="btn btn-sm btn-outline-danger"
                      onclick={{action "dropBnb" entry}}>Remove</button></td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{/if}}

        <label class="form-label"><strong>Add a Boon or Bane</strong></label>
        <PowerSelect @selected={{selectedCatalogue}} @options={{status.catalogue}}
          @searchField="name" @onChange={{action "selectCatalogue"}} as |entry|>
          {{entry.name}} [{{entry.tag}}] — {{entry.kind}}
        </PowerSelect>
        {{#if selectedCatalogue.description}}
          <p class="cg-tip mt-2">{{selectedCatalogue.description}}</p>
        {{/if}}
        <div class="row g-2 mt-2">
          <div class="col-md-3">
            <select class="form-select" aria-label="Boon or Bane level"
              onchange={{action (mut selectedLevel) value="target.value"}}>
              <option value="minor">Minor</option>
              <option value="major">Major</option>
              <option value="legendary">Legendary</option>
            </select>
          </div>
          <div class="col-md-7">
            <Input @type="text" @value={{explanation}} class="form-control"
              placeholder="Why does this apply to your character?" />
          </div>
          <div class="col-md-2">
            <button type="button" class="btn btn-primary w-100"
              disabled={{or (not selectedCatalogue) (not explanation)}}
              onclick={{action "addBnb"}}>Add</button>
          </div>
        </div>
      </div>
    </div>
  {{/if}}
</section>
