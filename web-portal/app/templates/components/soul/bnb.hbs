<section class="soul-bnb">
  <h3>Boons &amp; Banes</h3>
  <div class="input-group mb-3">
    <Input @value={{query}} class="form-control" placeholder="Search by name or tag" />
    <button type="button" class="btn btn-secondary" onclick={{action "search"}}>Search</button>
  </div>
  {{#if isLoading}}
    <div class="text-muted">Loading catalogue…</div>
  {{else}}
    <div class="list-group">
      {{#each entries as |entry|}}
        <button type="button" class="list-group-item list-group-item-action soul-bnb-entry"
          onclick={{action "showDetail" entry}}>
          <h5>#{{entry.id}} [{{entry.tag}}] {{entry.name}}</h5>
          <p>{{entry.description}}</p>
          <span class="badge bg-secondary">{{entry.kind}}</span>
        </button>
      {{/each}}
    </div>
  {{/if}}
  {{#if detail.catalogue}}
    <div class="card card-body mt-3">
      <h4>{{detail.catalogue.name}} [{{detail.catalogue.tag}}]</h4>
      <p>{{detail.catalogue.description}}</p>
      {{#if detail.owned_entry}}
        <p><strong>Your entry:</strong> {{detail.owned_entry.level_state}}</p>
        <p>{{detail.owned_entry.explanation}}</p>
      {{/if}}
      <button type="button" class="btn btn-secondary" onclick={{action "closeDetail"}}>Close</button>
    </div>
  {{/if}}
</section>
